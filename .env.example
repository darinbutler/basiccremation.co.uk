# Resend API key for callback form email delivery
# Get yours free at https://resend.com (3,000 emails/month free tier)
RESEND_API_KEY=re_your_key_here

# Email address callback form submissions are sent to
CALLBACK_EMAIL_TO=callbacks@basiccremation.co.uk

# Site URL (used for sitemap, canonical tags, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://basiccremation.co.uk

# Phone number displayed across the site
NEXT_PUBLIC_PHONE=0333 242 1405
